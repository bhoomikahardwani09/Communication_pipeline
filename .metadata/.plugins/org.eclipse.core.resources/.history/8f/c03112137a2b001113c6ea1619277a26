#include<stdio.h>
#include<string.h>
#include "stm32f411ceu6.h"

USART_Handle_t uart2;
GPIOx_HANDLE_t GPIO_LED;

char rx_buffer[64];
uint8_t rx_char, rx_idx = 0;
volatile uint8_t cmd_flag = 0, buffer_overflow_flag = 0;

void UART2_GPIO_Init(void);
void UART2_Init(void);
void decode_cmd(void);
void LED_GPIO_Init(void);

int main(void)
{
    UART2_GPIO_Init();

    UART2_Init();

    LED_GPIO_Init();

    //Enable the USART IRQ in the NVIC
    USART_IRQPriority(IRQ_NO_USART2, 15);
    USART_IRQConfig(IRQ_NO_USART2, ENABLE);

    //To enable the peripheral clock
    USART_PeriphCLKCtrl(uart2.pUSARTx, ENABLE);

    //Interrupt to receive the bytes
    USART_ReceiveDataIT(&uart2, &rx_char, 1);

    while(1)
    {
    	if(buffer_overflow_flag)
    	{
    		printf("[SYSTEM WARNING] : UART Rx buffer overflow!\r\n");
    		buffer_overflow_flag = 0;
    	}
    	//when full command is received
    	if(cmd_flag)
    	{
    		cmd_flag = 0;
    		rx_idx = 0;
    		decode_cmd();
    		memset(rx_buffer, 0, sizeof(rx_buffer));
    	}
    }
}

void UART2_GPIO_Init(void)
{
	GPIOx_HANDLE_t USART_Pins;
	USART_Pins.pGPIOx                                = GPIOA;
	USART_Pins.GPIO_PinConfig.GPIO_PinMode           = GPIO_MODE_ALTFN;
	USART_Pins.GPIO_PinConfig.GPIO_PinAltFunMode     = 7;
	USART_Pins.GPIO_PinConfig.GPIO_PinOPType         = GPIO_PUSH_PULL_Config;
	USART_Pins.GPIO_PinConfig.GPIO_PinPuPdControl    = GPIO_PU;
	USART_Pins.GPIO_PinConfig.GPIO_PinSpeed          = GPIO_SPEED_FAST;

	//USART2_RX
	USART_Pins.GPIO_PinConfig.GPIO_PinNumber = GPIO_PIN3;
	GPIO_Init(&USART_Pins);
}

void UART2_Init(void)
{
	uart2.pUSARTx                           = USART2;
	uart2.USART_Config.USART_Baudrate       = USART_STD_BAUD_115200;
	uart2.USART_Config.USART_ParityControl  = USART_PARITY_DI;
	uart2.USART_Config.USART_Stopbits       = USART_STOPBITS_1;
	uart2.USART_Config.WordLength           = USART_WORDLEN_8BITS;
	uart2.USART_Config.USART_HWFlowControl  = USART_HW_FLOW_CTRL_NONE;
	uart2.USART_Config.USART_Mode           = USART_MODE_RX;

	USART_Init(&uart2);

}

void LED_GPIO_Init(void)
{

	memset(&GPIO_LED, 0, sizeof(GPIO_LED));
	GPIO_LED.pGPIOx                              = GPIOC;
	GPIO_LED.GPIO_PinConfig.GPIO_PinNumber       = GPIO_PIN13;
	GPIO_LED.GPIO_PinConfig.GPIO_PinMode         = GPIO_MODE_OUT;
	GPIO_LED.GPIO_PinConfig.GPIO_PinSpeed        = GPIO_SPEED_FAST;
	GPIO_LED.GPIO_PinConfig.GPIO_PinOPType       = GPIO_OPEN_DRAIN_Config;
	GPIO_LED.GPIO_PinConfig.GPIO_PinPuPdControl  = GPIO_NO_PUPD;

	GPIO_Init(&GPIO_LED);

}
//ISR
void USART2_IRQHandler(void)
{
	USART_IRQHandling(&uart2);
}

void USART_ApplicationEventCallback(USART_Handle_t *pUSARTHandle, uint8_t AppEvent)
{
	if(AppEvent == USART_EV_RX_CMPLT)
	{
		if(rx_char == '\n')
		{
			rx_buffer[rx_idx] = '\0';
			cmd_flag = 1;
		}

		else if(rx_char != '\r')
		{
			rx_buffer[rx_idx++] = rx_char;
			if(rx_idx >= sizeof(rx_buffer))
			{
				buffer_overflow_flag = 1;
				rx_idx = 0;
				memset(rx_buffer, 0, sizeof(rx_buffer));
			}
		}

		USART_ReceiveDataIT(&uart2, &rx_char, 1);
	}

}
void decode_cmd(void)
{
	if(strncmp(rx_buffer, "motor:", 6) == 0)
	{
		int steps = 0, dir = 0;
		if(sscanf(rx_buffer, "motor:%d:%d", &steps, &dir) == 2)
		{
			printf("Stepper commands -> Steps : %d, Direction : %d", steps, dir);

		}

		else
		{
			printf("Invalid command format!\r\n");
		}
	}

	else if(strncmp(rx_buffer, "LED:", 4) == 0)
	{
		if(strstr(rx_buffer, "on") != NULL)
		{
			GPIO_WritetoOutputPin(GPIO_LED, GPIO_PIN13, 0);
		}

		else if(strstr(rx_buffer, "off") != NULL)
		{
			GPIO_WritetoOutputPin(GPIO_LED, GPIO_PIN13, 1);
		}

	}

	printf("Invalid command format..!!\r\n");
}



